{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "../../../out",
    "rootDir": "../../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "mocha", "vscode"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./**/*.ts"]
}
