{
  "name": "sidecar",
  "displayName": "SideCar",
  "description": "AI chat client for VS Code — use local Ollama models or Claude via the Anthropic API",
  "version": "0.6.0",
  "license": "MIT",
  "publisher": "nedonatelli",
  "author": {
    "name": "Nicholas Donatelli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nedonatelli/sidecar"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "icon": "media/SideCar.png",
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "ollama",
    "ai",
    "chat",
    "llama",
    "llm",
    "local",
    "mistral",
    "gemma",
    "codellama",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "SideCar",
      "properties": {
        "sidecar.baseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "API base URL (Ollama default: http://localhost:11434, Anthropic: https://api.anthropic.com)"
        },
        "sidecar.apiKey": {
          "type": "string",
          "default": "ollama",
          "description": "API key (ignored for local Ollama, required for Anthropic)"
        },
        "sidecar.model": {
          "type": "string",
          "default": "qwen3-coder:30b",
          "description": "Model to use for chat (e.g. qwen3-coder, qwen3.5, claude-sonnet-4-6)"
        },
        "sidecar.systemPrompt": {
          "type": "string",
          "default": "",
          "description": "System prompt override (optional)"
        },
        "sidecar.includeWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "Include workspace files in context"
        },
        "sidecar.filePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.ts",
            "**/*.js",
            "**/*.py",
            "**/*.md",
            "**/*.kt",
            "**/*.java",
            "**/*.swift",
            "**/*.go",
            "**/*.rs",
            "**/*.c",
            "**/*.cpp",
            "**/*.h",
            "**/*.rb",
            "**/*.php",
            "**/*.cs",
            "**/*.json",
            "**/*.yaml",
            "**/*.yml",
            "**/*.toml",
            "**/*.gradle.kts",
            "**/*.gradle",
            "**/*.html",
            "**/*.css",
            "**/*.scss",
            "**/*.sh",
            "**/*.sql"
          ],
          "description": "File patterns to include when building workspace context"
        },
        "sidecar.maxFiles": {
          "type": "number",
          "default": 10,
          "description": "Maximum number of files to include in workspace context"
        },
        "sidecar.toolPermissions": {
          "type": "object",
          "default": {},
          "description": "Per-tool permission overrides: { \"tool_name\": \"allow\" | \"deny\" | \"ask\" }"
        },
        "sidecar.hooks": {
          "type": "object",
          "default": {},
          "description": "Pre/post-execution hooks by tool name. Keys are tool names or '*' for all. Value: { \"pre\": \"command\", \"post\": \"command\" }"
        },
        "sidecar.scheduledTasks": {
          "type": "array",
          "default": [],
          "description": "Recurring tasks to run on interval",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "intervalMinutes": {
                "type": "number"
              },
              "prompt": {
                "type": "string"
              },
              "enabled": {
                "type": "boolean",
                "default": true
              }
            },
            "required": [
              "name",
              "intervalMinutes",
              "prompt"
            ]
          }
        },
        "sidecar.mcpServers": {
          "type": "object",
          "default": {},
          "description": "MCP servers to connect to. Format: { \"name\": { \"command\": \"npx\", \"args\": [\"-y\", \"@some/mcp-server\"] } }"
        },
        "sidecar.agentMode": {
          "type": "string",
          "enum": [
            "cautious",
            "autonomous",
            "manual"
          ],
          "default": "cautious",
          "description": "Agent approval mode: cautious (confirm writes), autonomous (auto-approve read/write, confirm destructive), manual (confirm everything)"
        },
        "sidecar.agentMaxIterations": {
          "type": "number",
          "default": 25,
          "description": "Maximum agent loop iterations before stopping"
        },
        "sidecar.agentMaxTokens": {
          "type": "number",
          "default": 100000,
          "description": "Maximum total tokens before stopping the agent loop"
        },
        "sidecar.includeActiveFile": {
          "type": "boolean",
          "default": true,
          "description": "Include the currently active file in chat context"
        },
        "sidecar.enableInlineCompletions": {
          "type": "boolean",
          "default": false,
          "description": "Enable inline code completions (Copilot-like autocomplete)"
        },
        "sidecar.completionModel": {
          "type": "string",
          "default": "",
          "description": "Model for inline completions (leave empty to use the chat model)"
        },
        "sidecar.completionMaxTokens": {
          "type": "number",
          "default": 256,
          "description": "Maximum tokens for inline completion responses"
        },
        "sidecar.completionDebounceMs": {
          "type": "number",
          "default": 300,
          "description": "Minimum interval in milliseconds between completion requests"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sidecar-view-container",
          "title": "SideCar",
          "icon": "media/SideCar.png"
        }
      ]
    },
    "views": {
      "sidecar-view-container": [
        {
          "type": "webview",
          "id": "sidecar.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "sidecar.toggleChat",
        "title": "Toggle SideCar Chat"
      },
      {
        "command": "sidecar.explainSelection",
        "title": "Explain with SideCar"
      },
      {
        "command": "sidecar.fixSelection",
        "title": "Fix with SideCar"
      },
      {
        "command": "sidecar.refactorSelection",
        "title": "Refactor with SideCar"
      },
      {
        "command": "sidecar.inlineChat",
        "title": "SideCar: Inline Chat"
      },
      {
        "command": "sidecar.reviewChanges",
        "title": "SideCar: Review Changes"
      }
    ],
    "keybindings": [
      {
        "command": "sidecar.toggleChat",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      },
      {
        "command": "sidecar.inlineChat",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "sidecar.explainSelection",
          "when": "editorHasSelection",
          "group": "sidecar@1"
        },
        {
          "command": "sidecar.fixSelection",
          "when": "editorHasSelection",
          "group": "sidecar@2"
        },
        {
          "command": "sidecar.refactorSelection",
          "when": "editorHasSelection",
          "group": "sidecar@3"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
